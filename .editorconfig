# EditorConfig — keeps indentation consistent across editors
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

# Site source files use 4-space indentation (matches ESLint indent rule)
[*.{html,css,js}]
indent_size = 4

# Playwright tests and config use 2-space indentation
[{tests/**.js,playwright.config.js}]
indent_size = 2

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
# Trailing whitespace is meaningful in Markdown (line breaks)
trim_trailing_whitespace = false
indent_size = 2
